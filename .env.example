# .env.example for backend
# copy to .env and fill in values

# Google / Gemini LLM API key
LLM_API_KEY=AIzaSyBfK2mcrnngGZI5Qc3d45LYEIZKa6DdnaE
# (OR) GOOGLE_API_KEY=your_api_key_here

# SQLite file path (optional)
# If you are using SQLite on Render, set DB_PATH to a writable path such as
# /scratch/data/products.db. The application defaults to /tmp/products.db when
# DB_PATH is not provided (useful for local development).
DB_PATH=/tmp/products.db

# PostgreSQL connection URL; Render provides this automatically when you add a postgres database
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:port/dbname
